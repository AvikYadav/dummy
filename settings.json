{
  "frontend": {
    "framework": "html",
    "root": "frontend",
    "hosting": {
      "type": "static",
      "route": "/"
    },
    "entrypoints": [
      {
        "file": "frontend/index.html",
        "dependencies": {
          "files": [
            "frontend/css/style.css",
            "frontend/js/app.js"
          ],
          "directories": [
            "frontend/assets"
          ]
        }
      },
      {
        "file": "frontend/about.html",
        "dependencies": {
          "files": [
            "frontend/css/style.css"
          ]
        }
      }
    ],
    "build": {
      "required": false,
      "command": null,
      "output_directory": null
    }
  }
}
